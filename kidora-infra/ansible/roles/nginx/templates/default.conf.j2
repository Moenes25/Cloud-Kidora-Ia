# {{ ansible_managed }}
# Nginx configuration for Kidora
# Managed by Ansible - DO NOT EDIT MANUALLY

server {
    listen 80;
    server_name {{ nginx_server_name }};

    return 301 https://$host$request_uri;
}


server {
    listen 443 ssl;
    server_name {{ nginx_server_name }};


    ssl_certificate {{ nginx_ssl_certificate }};
    ssl_certificate_key {{ nginx_ssl_certificate_key }};


    location / {
        proxy_pass {{ nginx_frontend_url }};

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /api/ {
        proxy_pass {{ nginx_backend_url }};

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # WebSocket endpoint - handles SockJS and WS connections
    location /ws/ {
        proxy_pass {{ nginx_backend_url }};

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Mobile app API (controllers_mobile: /mobile, /mobile/auth,
    # /mobile/chat, /mobile/payment, /mobile/presence, /mobile/notes,
    # /mobile/repas, /mobile/ai, /mobile/notification, etc.)
    location /mobile/ {
        proxy_pass {{ nginx_backend_url }};

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }


    location /kidora/ {
        proxy_pass {{ nginx_minio_url }}/kidora/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /uploads/ {
        proxy_pass {{ nginx_minio_url }}/kidora/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # AI Backend API endpoint
    location /ai/ {
        proxy_pass {{ nginx_ai_backend_url }}/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
    location /api/ai/ {
        proxy_pass {{ nginx_ai_backend_url }}/api/ai/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}