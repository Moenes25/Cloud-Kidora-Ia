{
    "distSpecVersion": "1.1.0",
    "storage": {
        "rootDirectory": "/var/lib/registry"
    },
    "http": {
        "address": "0.0.0.0",
        "port": "5000",
        "tls": {
            "cert": "/etc/zot/certs/cert.pem",
            "key": "/etc/zot/certs/key.pem"
        }
    },
    "log": {
        "level": "info"
    },
    "extensions": {
        "ui": {
            "enable": true
        },
        "search": {
            "enable": true
        }
    }
}