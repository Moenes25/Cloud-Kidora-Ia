LLM_MAX_TOKENS=2048
LLM_MEMORY_WINDOW=10
APP_NAME=Générateur de Rapports Éducatifs IA
ENVIRONMENT=production
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://kidora.freeddns.org,https://kidora.freeddns.org
