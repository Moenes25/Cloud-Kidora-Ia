# ═══════════════════════════════════════════════
# Kidora — Environment Variables (Root)
# ═══════════════════════════════════════════════
# This file is only an EXAMPLE / reference.
# Secrets MUST NOT be committed. Create a local, gitignored `.env`
# next to this file and export/define the real values there.
# Docker Compose and the Ansible templates read these via
# `${VAR}` interpolation (and `{{ var }}` for Ansible), so the
# actual keys are resolved from the environment / `.env`, not here.
# ═══════════════════════════════════════════════

# Domain
DOMAIN_NAME=kidora.freeddns.org
EMAIL_FOR_SSL=admin@kidora.freeddns.org

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=${MONGO_INITDB_ROOT_PASSWORD}
MONGO_INITDB_DATABASE=kidora
MONGO_PORT=27017

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD}
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Application
APP_BACKEND_PORT=8086
APP_FRONTEND_PORT=80

# AI Backend Configuration
# Real keys are provided via the environment / local .env (see note above).
GROQ_API_KEY=${GROQ_API_KEY}
GROQ_MODEL_NAME=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_MEMORY_WINDOW=10
APP_NAME=Générateur de Rapports Éducatifs IA
ENVIRONMENT=production
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://kidora.freeddns.org,https://kidora.freeddns.org
LOG_LEVEL=INFO
BFL_API_KEY=${BFL_API_KEY}
IMAGE_PROVIDER=gemini
POLLINATIONS_API_KEY=${POLLINATIONS_API_KEY}

# Monitoring
GRAFANA_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD}
PROMETHEUS_RETENTION_DAYS=30

# Traefik Dashboard
TRAEFIK_ADMIN_USER=admin
# Generate with: htpasswd -nb admin yourpassword
TRAEFIK_ADMIN_PASSWORD_HASH=${TRAEFIK_ADMIN_PASSWORD_HASH}

# Volume mount points (on the server)
DATA_MOUNT_POINT=/mnt/data
BACKUP_MOUNT_POINT=/mnt/backup