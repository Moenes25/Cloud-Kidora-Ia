# ═══════════════════════════════════════════════
# Kidora — Environment Variables (Root)
# ═══════════════════════════════════════════════
# This file is only for local reference.
# The actual .env is generated by Ansible on the server.
# ═══════════════════════════════════════════════

# Domain
DOMAIN_NAME=kidora.example.com
EMAIL_FOR_SSL=admin@example.com

# MongoDB
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=change_me_mongodb
MONGO_INITDB_DATABASE=kidora
MONGO_PORT=27017

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Application
APP_BACKEND_PORT=8086
APP_FRONTEND_PORT=80

# Monitoring
GRAFANA_ADMIN_PASSWORD=change_me_grafana
PROMETHEUS_RETENTION_DAYS=30

# Traefik Dashboard
TRAEFIK_ADMIN_USER=admin
# Generate with: htpasswd -nb admin yourpassword
TRAEFIK_ADMIN_PASSWORD_HASH=admin:$2y$05$examplehash

# Volume mount points (on the server)
DATA_MOUNT_POINT=/mnt/data
BACKUP_MOUNT_POINT=/mnt/backup