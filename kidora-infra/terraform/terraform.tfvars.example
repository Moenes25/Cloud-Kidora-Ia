# ═══════════════════════════════════════════════
# Kidora Infrastructure — Terraform Variables (Vultr)
# ═══════════════════════════════════════════════
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
# ═══════════════════════════════════════════════

# Required: Your Vultr API key (generate at https://my.vultr.com/settings/#api)
vultr_api_key = "YOUR_VULTR_API_KEY"

# Required: Your SSH public key (get with: cat ~/.ssh/id_rsa.pub)
ssh_public_key = "ssh-rsa AAAA... your-key-here"

# Server configuration - using lowest tier for testing
server_name  = "kidora-test"
server_type  = "vc2-1c-1gb"     # 1 vCPU, 1GB RAM, 25GB SSD - lowest Vultr tier
location     = "ewr"           # New Jersey - options: lax (LA), sjc (Silicon Valley), ams (Amsterdam), etc.
os_image     = "1743"           # Ubuntu 24.04 x64 - see https://www.vultr.com/api/ for other OS images

# ⚠️ SECURITY: Replace with your specific IP in production!
# In production, restrict to your office/home IP: ["YOUR.IP.ADDRESS/32"]
ssh_allowed_ips     = ["0.0.0.0/0"]
firewall_allowed_ips = ["0.0.0.0/0"]

# Application domain
domain_name    = "kidora.example.com"
email_for_ssl  = "admin@example.com"

# Storage volumes (in GB) - kept small for testing
backup_volume_size = 10   # 10GB for backups
data_volume_size   = 25   # 25GB for MongoDB + MinIO data